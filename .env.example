API_URL=
CREDENTIAL_CLIENT_ID=
CREDENTIAL_SECRET=


# -----------------------------------------------------------------------------
# Authentication (NextAuth.js)
# -----------------------------------------------------------------------------
NEXTAUTH_BASEPATH=${BASEPATH}/api/auth
NEXTAUTH_URL=http://localhost:3001${BASEPATH}/api/auth
NEXTAUTH_SECRET=rvuEsh635H93/Dg7nK7ZLJfzJQuQ9NNqFPgBjpUDths=

# Google OAuth 2.0 (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=

# -----------------------------------------------------------------------------
# Object Storage (S3-compatible: MinIO, AWS S3, Cloudflare R2, Backblaze B2)
# -----------------------------------------------------------------------------

# Provider name (for reference / logging): minio | s3 | r2 | backblaze
STORAGE_PROVIDER=minio

# Bucket name
STORAGE_BUCKET=paperless

# Region (use "us-east-1" for MinIO, "auto" for R2)
STORAGE_REGION=us-east-1

# Access Key & Secret
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin

# Custom endpoint — REQUIRED for MinIO, R2, Backblaze; leave empty for AWS S3
STORAGE_ENDPOINT=http://localhost:9000

# Public base URL for building download links
# MinIO same-host:   http://localhost:9000
# MinIO behind CDN:  https://storage.example.com
# Leave empty to auto-build from endpoint + bucket
STORAGE_PUBLIC_URL=http://localhost:9000/paperless

# Force path-style URLs: "true" = endpoint/bucket/key (required for MinIO)
# "false" = bucket.endpoint/key (AWS virtual-hosted style)
# Default: "true" for all providers except s3
STORAGE_USE_PATH_STYLE=true